{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VESPERTTINE RAYFIN EDITOR",
  "version": "0.93.0",
  "identifier": "com.vesperttine.rayfineditor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VESPERTTINE RAYFIN EDITOR",
        "width": 1360,
        "height": 880,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "backgroundColor": "#0b0e14",
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "VESPERTTINE RAYFIN EDITOR",
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 Sachin Patney",
    "resources": {
      "../resources/telemetry*.json": "resources/",
      "../resources/fabricator-templates/": "resources/fabricator-templates/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4NEEyQzBFMTA1MUFCMzAKUldRd3ExRVFEaXhLR09weDZNcGk3VVkwbTI0OS9tU0RqTHd2cU82Zjk4dml5LzZOSTVjeTM5S2cK",
      "endpoints": [
        "https://github.com/spatney/rayfin-fabricator/releases/latest/download/latest.json"
      ]
    }
  }
}
